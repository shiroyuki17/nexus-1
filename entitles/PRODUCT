{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "drinks",
        "snacks",
        "meals",
        "combo"
      ],
      "default": "drinks"
    },
    "price": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "available": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "category",
    "price"
  ]
