generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  email           String   @unique
  phone           String?
  address         String?
  logo_url        String?
  status          String   @default("active")
  max_pcs         Int      @default(50)
  max_users       Int      @default(500)
  settings        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  subscription    Subscription?
  pcs             PC[]
  users           UserProfile[]
  reservations    Reservation[]
  games           Game[]
  products        Product[]
  foodOrders      FoodOrder[]
  tournaments     Tournament[]
  transactions    Transaction[]
}

model Subscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  plan            String   @default("basic")
  status          String   @default("active")
  startDate       DateTime @default(now())
  endDate         DateTime?
  monthlyPrice    Float    @default(0)
  features        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model UserProfile {
  id            String    @id @default(cuid())
  tenantId      String
  user_id       String    @unique
  username      String
  avatar_url    String?
  balance       Float     @default(0)
  points        Float     @default(0)
  rank          String    @default("Bronze")
  total_hours   Float     @default(0)
  current_pc    Int?
  session_active Boolean  @default(false)
  session_start DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@index([user_id])
}

model PC {
  id              String    @id @default(cuid())
  tenantId        String
  pc_number       Int       @unique
  zone            String    @default("standard")
  status          String    @default("available")
  specs           String?
  current_user_id String?
  session_start   DateTime?
  hourly_rate     Float     @default(5)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model Reservation {
  id             String   @id @default(cuid())
  tenantId       String
  user_id        String
  user_name      String?
  pc_id          String
  pc_number      Int?
  zone           String?
  date           DateTime
  start_time     String
  end_time       String?
  duration_hours Float
  status         String   @default("pending")
  total_cost     Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model Game {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  category    String
  description String?
  image_url   String?
  is_featured Boolean  @default(false)
  popularity  Float    @default(0)
  min_specs   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String   @default("drinks")
  price       Float
  description String?
  image_url   String?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model FoodOrder {
  id        String   @id @default(cuid())
  tenantId  String
  user_id   String
  user_name String?
  items     Json
  total     Float
  status    String   @default("pending")
  pc_number Int?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model Tournament {
  id                   String   @id @default(cuid())
  tenantId             String
  title                String
  game                 String
  description          String?
  date                 DateTime
  time                 String?
  max_participants     Int?
  current_participants Int      @default(0)
  prize_pool           String?
  entry_fee            Float    @default(0)
  status               String   @default("upcoming")
  image_url            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model TournamentRegistration {
  id            String   @id @default(cuid())
  tournament_id String
  user_id       String
  user_name     String?
  team_name     String?
  status        String   @default("registered")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id            String   @id @default(cuid())
  tenantId      String
  user_id       String
  type          String
  amount        Float
  description   String?
  balance_after Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
}

model EventLog {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  entity      String?
  entityId    String?
  payload     Json
  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
